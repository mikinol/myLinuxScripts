unset NIX_ENFORCE_NO_NATIVE

SRC="$DIR/../src/$NAME.c"
OUT="$DIR/../build_cache/$NAME"

[ ! -f "$SRC" ] && { echo "Ошибка: $SRC не найден!"; exit 1; }
mkdir -p "$DIR/../build_cache"

[ ! -f "$OUT" ] || [ "$SRC" -nt "$OUT" ] && cc -s -O2 -Wall -march=native -pipe -o "$OUT" "$SRC" || true
exec "$OUT" "$@"

