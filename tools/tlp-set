#!/bin/sh

PROFILE=$1
CACHE_FILE="$HOME/.cache/tlp_profile"

# Функция применения (чтобы не дублировать код)
apply_tlp() {
    mode=$1
    case $mode in
        performance)
            sudo tlp performance
            notify-send -t 1500 "Power" "🚀 BOOST"
            ;;
        power-saver)
            sudo tlp power-saver
            notify-send -t 1500 "Power" "🔋 ECO"
            ;;
        *) # По умолчанию или 'auto'
            sudo tlp start
            notify-send -t 1500 "Power" "⚖️ BALANCED"
            mode="auto"
            ;;
    esac
    echo "$mode" > "$CACHE_FILE"
}

if [ "$PROFILE" = "restore" ]; then
    # Читаем старое значение, если пусто — ставим auto
    SAVED=$(cat "$CACHE_FILE" 2>/dev/null || echo "auto")
    apply_tlp "$SAVED"
else
    # Обычная установка нового режима
    apply_tlp "$PROFILE"
fi
