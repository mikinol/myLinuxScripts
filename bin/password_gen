#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
NAME="password_gen"

COMPILER_FLAGS="-fno-math-errno -fno-trapping-math -freciprocal-math -fassociative-math -fomit-frame-pointer"

if [ ! -d "/data/data/com.termux" ]; then
    COMPILER_FLAGS="$COMPILER_FLAGS -static -nostdlib -fno-builtin"
fi

. "$DIR/../tools/compile_wrapper"
